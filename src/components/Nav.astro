---
---
<header class="site-header" role="banner">
  <div class="site-header__inner">
    <a href="/" class="wordmark" aria-label="news.dehor.com.br - pagina inicial">
      news.dehor.com.br
    </a>
    <nav aria-label="Navegacao principal">
      <ul class="header-links">
        <li>
          <a
            href="https://github.com/nikolasdehor"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub de Nikolas de Hor (abre em nova aba)"
          >
            GitHub
          </a>
        </li>
        <li>
          <a href="/rss.xml" aria-label="Feed RSS global">
            RSS
          </a>
        </li>
        <li>
          <button
            id="theme-toggle"
            class="theme-toggle"
            aria-label="Alternar tema claro e escuro"
            title="Alternar tema"
            type="button"
          >
            <!-- Icone sol (exibido no dark para trocar para light) -->
            <svg class="theme-toggle__sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="3" stroke="currentColor" stroke-width="1.5"/>
              <path stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                d="M8 1.5V3M8 13v1.5M1.5 8H3M13 8h1.5M3.34 3.34l1.06 1.06M11.6 11.6l1.06 1.06M3.34 12.66l1.06-1.06M11.6 4.4l1.06-1.06"/>
            </svg>
            <!-- Icone lua (exibido no light para trocar para dark) -->
            <svg class="theme-toggle__moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
                d="M13.5 9.5A6 6 0 0 1 6.5 2.5a5.5 5.5 0 1 0 7 7z"/>
            </svg>
          </button>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('theme-toggle');
  if (toggle) {
    toggle.addEventListener('click', () => {
      const html = document.documentElement;
      const current = html.getAttribute('data-theme') ?? 'dark';
      const next = current === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      try {
        localStorage.setItem('theme', next);
      } catch (_) {}
    });
  }
</script>
