---
/**
 * SubscribeForm - Formulario de inscricao segmentada por projeto
 *
 * Props:
 *   projects:     lista de projetos disponiveis
 *   preChecked:   slugs pre-selecionados (ex: pagina de projeto)
 *   heading:      titulo opcional da secao
 */
export interface ProjectOption {
  slug: string;
  label: string;
}

interface Props {
  projects: ProjectOption[];
  preChecked?: string[];
  heading?: string;
}

const {
  projects,
  preChecked = [],
  heading = 'Receba as novidades',
} = Astro.props;

const formId = `subscribe-form-${Math.random().toString(36).slice(2, 8)}`;
---

<section class="subscribe-section" aria-labelledby={`${formId}-heading`}>
  <div class="subscribe-box">
    <h2 class="subscribe-heading" id={`${formId}-heading`}>{heading}</h2>
    <p class="subscribe-subtext">
      Fique por dentro das atualizações. Sem spam - só novidades dos projetos que você escolher.
    </p>

    <form
      class="subscribe-form"
      id={formId}
      novalidate
      aria-describedby={`${formId}-status`}
    >
      <!-- Honeypot anti-spam (oculto, nao preenchido por humanos) -->
      <div class="subscribe-honeypot" aria-hidden="true">
        <label for={`${formId}-website`}>Website</label>
        <input
          type="text"
          id={`${formId}-website`}
          name="website"
          tabindex="-1"
          autocomplete="off"
        />
      </div>

      <!-- Selecao de projetos -->
      {projects.length > 1 && (
        <fieldset class="subscribe-projects">
          <legend class="subscribe-projects__legend">Projetos</legend>
          {projects.map((proj) => (
            <label class="subscribe-checkbox">
              <input
                type="checkbox"
                name="projects"
                value={proj.slug}
                checked={preChecked.includes(proj.slug)}
              />
              <span>{proj.label}</span>
            </label>
          ))}
        </fieldset>
      )}

      {/* Se so ha 1 projeto, usa input hidden */}
      {projects.length === 1 && (
        <input type="hidden" name="projects" value={projects[0].slug} />
      )}

      <!-- Email -->
      <div class="subscribe-field">
        <label class="subscribe-label" for={`${formId}-email`}>E-mail</label>
        <input
          class="subscribe-input"
          type="email"
          id={`${formId}-email`}
          name="email"
          placeholder="seu@email.com"
          autocomplete="email"
          required
          aria-required="true"
        />
      </div>

      <!-- Botao -->
      <button class="subscribe-btn" type="submit">
        <span class="subscribe-btn__label">Inscrever</span>
        <span class="subscribe-btn__loading" aria-hidden="true">Enviando...</span>
      </button>

      <!-- Feedback -->
      <div
        id={`${formId}-status`}
        class="subscribe-status"
        role="status"
        aria-live="polite"
        aria-atomic="true"
      ></div>
    </form>
  </div>
</section>

<script define:vars={{ formId }}>
  (function () {
    const form = document.getElementById(formId);
    if (!form) return;

    const emailInput = form.querySelector('[name="email"]');
    const btnLabel = form.querySelector('.subscribe-btn__label');
    const btnLoading = form.querySelector('.subscribe-btn__loading');
    const statusEl = form.querySelector('.subscribe-status');
    const btn = form.querySelector('.subscribe-btn');

    function setLoading(loading) {
      btn.disabled = loading;
      btn.classList.toggle('subscribe-btn--loading', loading);
      btnLabel.hidden = loading;
      btnLoading.hidden = !loading;
    }

    function setStatus(type, message) {
      statusEl.textContent = message;
      statusEl.className = 'subscribe-status subscribe-status--' + type;
    }

    function getSelectedProjects() {
      const checkboxes = form.querySelectorAll('[name="projects"]:checked');
      const hidden = form.querySelectorAll('input[type="hidden"][name="projects"]');
      const values = [];
      checkboxes.forEach((cb) => values.push(cb.value));
      hidden.forEach((h) => values.push(h.value));
      return values;
    }

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      setStatus('', '');

      const email = emailInput.value.trim();
      if (!email) {
        setStatus('error', 'Informe seu e-mail.');
        emailInput.focus();
        return;
      }

      const website = form.querySelector('[name="website"]')?.value ?? '';
      const projects = getSelectedProjects();

      if (projects.length === 0) {
        setStatus('error', 'Selecione ao menos um projeto.');
        return;
      }

      setLoading(true);
      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, projects, website }),
        });
        const data = await res.json().catch(() => ({ ok: false }));

        if (data.ok) {
          setStatus('success', 'Pronto! Você vai receber as novidades.');
          form.reset();
        } else {
          setStatus('error', data.error || 'Algo deu errado. Tente novamente.');
        }
      } catch {
        setStatus('error', 'Erro de conexão. Verifique sua internet e tente novamente.');
      } finally {
        setLoading(false);
      }
    });
  })();
</script>

<style>
  /* ---- Secao ---- */
  .subscribe-section {
    padding-block: var(--space-16);
  }

  .subscribe-box {
    max-width: var(--width-narrow);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* ---- Texto ---- */
  .subscribe-heading {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    color: var(--color-text-primary);
    margin-bottom: var(--space-3);
    font-weight: 700;
    line-height: var(--leading-tight);
  }

  .subscribe-subtext {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin-bottom: var(--space-8);
    line-height: var(--leading-relaxed);
  }

  /* ---- Form ---- */
  .subscribe-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  /* ---- Honeypot ---- */
  .subscribe-honeypot {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
    pointer-events: none;
  }

  /* ---- Projetos (checkboxes) ---- */
  .subscribe-projects {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .subscribe-projects__legend {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-text-muted);
    padding-inline: var(--space-2);
  }

  .subscribe-checkbox {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    cursor: pointer;
    font-size: var(--text-sm);
    color: var(--color-text-body);
    user-select: none;
  }

  .subscribe-checkbox input[type="checkbox"] {
    appearance: none;
    -webkit-appearance: none;
    width: 16px;
    height: 16px;
    min-width: 16px;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    cursor: pointer;
    position: relative;
    transition:
      border-color var(--duration-fast) ease,
      background-color var(--duration-fast) ease;
  }

  .subscribe-checkbox input[type="checkbox"]:checked {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .subscribe-checkbox input[type="checkbox"]:checked::after {
    content: '';
    position: absolute;
    top: 2px;
    left: 4px;
    width: 5px;
    height: 8px;
    border: 2px solid #fff;
    border-top: none;
    border-left: none;
    transform: rotate(45deg);
  }

  .subscribe-checkbox:hover input[type="checkbox"]:not(:checked) {
    border-color: var(--color-accent);
  }

  .subscribe-checkbox input[type="checkbox"]:focus-visible {
    outline: 3px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* ---- Campo de email ---- */
  .subscribe-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .subscribe-label {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .subscribe-input {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-text-primary);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    outline: none;
    transition:
      border-color var(--duration-fast) ease,
      box-shadow var(--duration-fast) ease;
  }

  .subscribe-input::placeholder {
    color: var(--color-text-faint);
  }

  .subscribe-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-subtle);
  }

  /* ---- Botao ---- */
  .subscribe-btn {
    padding: var(--space-3) var(--space-6);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    color: #fff;
    background: var(--color-accent);
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition:
      background-color var(--duration-fast) ease,
      transform var(--duration-fast) ease,
      opacity var(--duration-fast) ease;
    align-self: flex-start;
    min-width: 120px;
    text-align: center;
  }

  .subscribe-btn:hover:not(:disabled) {
    background: var(--color-accent-hover);
  }

  .subscribe-btn:focus-visible {
    outline: 3px solid var(--color-accent);
    outline-offset: 2px;
  }

  .subscribe-btn:active:not(:disabled) {
    transform: translateY(1px);
  }

  .subscribe-btn:disabled {
    opacity: 0.65;
    cursor: not-allowed;
  }

  .subscribe-btn__loading {
    display: none;
  }

  .subscribe-btn--loading .subscribe-btn__label {
    display: none;
  }

  .subscribe-btn--loading .subscribe-btn__loading {
    display: inline;
  }

  /* ---- Status ---- */
  .subscribe-status {
    font-size: var(--text-sm);
    border-radius: var(--radius-md);
    min-height: 1.5rem;
    transition: opacity var(--duration-fast) ease;
  }

  .subscribe-status--success {
    color: var(--color-accent);
    font-weight: 500;
  }

  .subscribe-status--error {
    color: #c0392b;
  }

  [data-theme="dark"] .subscribe-status--error {
    color: #ff6b6b;
  }

  /* ---- Responsivo ---- */
  @media (max-width: 480px) {
    .subscribe-btn {
      width: 100%;
    }
  }
</style>
