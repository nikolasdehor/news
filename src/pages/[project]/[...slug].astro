---
import { getCollection, render } from 'astro:content';
import Head from '../../components/Head.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';

export async function getStaticPaths() {
  const todos = await getCollection('posts', ({ data }) => !data.draft);

  return todos.map((post) => {
    const [project, ...restParts] = post.id.split('/');
    const slug = restParts.join('/');

    return {
      params: { project, slug },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { project, slug } = Astro.params;
const { Content } = await render(post);

const canonicalURL = new URL(`/${project}/${slug}/`, Astro.site);

// Nomes de display por projeto
const nomesProjeto: Record<string, string> = {
  'mcp-fiscal-brasil': 'MCP Fiscal Brasil',
};
const nomeProjeto = nomesProjeto[project] ?? project;

// Numero da edicao a partir do slug (ex: "edicao-1" -> "01")
const matchNum = slug.match(/(\d+)$/);
const numEdicao = matchNum ? String(parseInt(matchNum[1], 10)).padStart(2, '0') : null;

// Estimativa de tempo de leitura
const palavrasPorMinuto = 220;
const textoEstimado = post.data.description.length * 8; // aproximacao
const minutos = Math.max(1, Math.round(textoEstimado / palavrasPorMinuto));
---

<html lang="pt-BR">
  <head>
    <Head
      title={post.data.title}
      description={post.data.description}
      canonicalURL={canonicalURL}
      ogImage={post.data.ogImage}
      pubDate={post.data.pubDate}
      project={project}
    />
    <link rel="icon" type="image/png" href="/logo-mcp-fiscal.png" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <Nav />

    <main>
      <!-- Cabecalho do post -->
      <header class="post-header">
        <div class="post-header__inner">
          <a href={`/${project}/`} class="breadcrumb">
            &larr; {nomeProjeto}
          </a>

          {numEdicao && (
            <p class="post-edition-label">EDIÇÃO {numEdicao}</p>
          )}

          <h1 class="post-title">{post.data.title}</h1>

          <div class="post-byline-bar">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('pt-BR', {
                day: '2-digit',
                month: 'long',
                year: 'numeric',
                timeZone: 'America/Sao_Paulo',
              })}
            </time>
            <span class="post-byline-bar__dot" aria-hidden="true">&middot;</span>
            <span>Nikolas de Hor</span>
            {post.data.tags && post.data.tags.length > 0 && (
              <>
                <span class="post-byline-bar__dot" aria-hidden="true">&middot;</span>
                <span class="badge">{post.data.tags[0]}</span>
              </>
            )}
          </div>
        </div>
      </header>

      <!-- Corpo do artigo -->
      <article class="prose">
        <Content />
      </article>

      <!-- Rodape do post -->
      <div class="post-footer">
        <nav class="post-footer__nav" aria-label="Navegacao entre posts">
          <a href={`/${project}/`} class="back-link">
            &larr; Voltar para {nomeProjeto}
          </a>
        </nav>
        <div class="post-footer__note">
          <p>
            Gostou desta edição? Acompanhe o projeto no GitHub:
            <a
              href="https://github.com/nikolasdehor"
              target="_blank"
              rel="noopener noreferrer"
            >
              github.com/nikolasdehor
            </a>
          </p>
        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>
