---
import { getCollection } from 'astro:content';
import Head from '../../components/Head.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';

export async function getStaticPaths() {
  const todos = await getCollection('posts', ({ data }) => !data.draft);
  const projetos = [...new Set(todos.map((p) => p.data.project))];

  return projetos.map((project) => ({
    params: { project },
    props: {
      posts: todos
        .filter((p) => p.data.project === project)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { project } = Astro.params;
const { posts } = Astro.props;

// Metadados por projeto
const metaProjetos: Record<string, {
  nome: string;
  desc: string;
  logo: string;
  github: string;
  tags: string[];
}> = {
  'mcp-fiscal-brasil': {
    nome: 'MCP Fiscal Brasil',
    desc: 'Servidor MCP com 44 tools para dados fiscais brasileiros - CNPJ, NF-e, SPED, BCB e Reforma Tributária.',
    logo: '/logo-mcp-fiscal.png',
    github: 'https://github.com/DeHor-Labs/mcp-fiscal-brasil',
    tags: ['Python', 'MCP', 'Dados Fiscais', 'NF-e', 'Open Source'],
  },
};

const meta = metaProjetos[project] ?? {
  nome: project,
  desc: `Diário de bordo do projeto ${project}.`,
  logo: '',
  github: '',
  tags: [],
};

const primeiraData = posts[posts.length - 1]?.data.pubDate;
const desde = primeiraData
  ? primeiraData.toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' })
  : '';
---

<html lang="pt-BR">
  <head>
    <Head
      title={meta.nome}
      description={meta.desc}
      canonicalURL={new URL(`/${project}/`, Astro.site)}
      project={project}
    />
    <link rel="icon" type="image/png" href="/logo-mcp-fiscal.png" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <Nav />

    <!-- Cabeçalho do projeto -->
    <header class="project-header" aria-labelledby="project-title">
      <div class="project-header__inner">
        <a href="/" class="back-link">&larr; Todos os projetos</a>

        <div class="project-header__meta">
          {meta.logo && (
            <img
              src={meta.logo}
              alt={`Logo ${meta.nome}`}
              class="project-header__logo"
              width="72"
              height="72"
              loading="eager"
            />
          )}
          <div class="project-header__info">
            <h1 class="project-header__title" id="project-title">{meta.nome}</h1>
            {meta.tags.length > 0 && (
              <div class="project-header__tags">
                {meta.tags.map((tag) => (
                  <span class="tech-tag">{tag}</span>
                ))}
              </div>
            )}
            {meta.github && (
              <div class="project-header__actions">
                <a
                  href={meta.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn-outline"
                >
                  GitHub &nearr;
                </a>
                <a
                  href={`/${project}/rss.xml`}
                  class="btn-outline"
                  aria-label={`Feed RSS do projeto ${meta.nome}`}
                >
                  RSS &nearr;
                </a>
              </div>
            )}
            {desde && (
              <p class="project-header__count">
                {posts.length} {posts.length === 1 ? 'edição publicada' : 'edições publicadas'} desde {desde}
              </p>
            )}
          </div>
        </div>
      </div>
    </header>

    <main>
      <section class="section" aria-labelledby="edicoes-titulo">
        <div class="container">
          <div class="section__header">
            <p class="eyebrow">Arquivo</p>
            <h2 class="section__title" id="edicoes-titulo">Todas as edições</h2>
          </div>
          <div class="editions-list">
            {posts.map((post, idx) => {
              const [, ...restParts] = post.id.split('/');
              const slug = restParts.join('/');
              const numEdition = String(posts.length - idx).padStart(3, '0');
              return (
                <article class="edition-row">
                  <span class="edition-number" aria-hidden="true">#{numEdition}</span>
                  <div class="edition-content">
                    <h3 class="edition-content__title">
                      <a href={`/${project}/${slug}/`} class="post-link">
                        {post.data.title}
                      </a>
                    </h3>
                    <p class="edition-content__excerpt">{post.data.description}</p>
                    <div class="edition-content__meta">
                      <time datetime={post.data.pubDate.toISOString()}>
                        {post.data.pubDate.toLocaleDateString('pt-BR', {
                          day: '2-digit',
                          month: 'long',
                          year: 'numeric',
                        })}
                      </time>
                      <a href={`/${project}/${slug}/`}>Ler &rarr;</a>
                    </div>
                  </div>
                </article>
              );
            })}
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>
