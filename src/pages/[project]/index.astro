---
import { getCollection } from 'astro:content';
import Head from '../../components/Head.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import SubscribeForm from '../../components/SubscribeForm.astro';
import '../../styles/global.css';

export async function getStaticPaths() {
  const todos = await getCollection('posts', ({ data }) => !data.draft);
  const projetos = [...new Set(todos.map((p) => p.data.project))];

  return projetos.map((project) => ({
    params: { project },
    props: {
      posts: todos
        .filter((p) => p.data.project === project)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { project } = Astro.params;
const { posts } = Astro.props;

// Metadados por projeto
const metaProjetos: Record<string, {
  nome: string;
  desc: string;
  github: string;
  tags: string[];
}> = {
  'mcp-fiscal-brasil': {
    nome: 'MCP Fiscal Brasil',
    desc: 'Servidor MCP em Python para consulta de dados fiscais e tributários brasileiros.',
    github: 'https://github.com/DeHor-Labs/mcp-fiscal-brasil',
    tags: ['Python', 'MCP', 'Open Source'],
  },
};

const meta = metaProjetos[project] ?? {
  nome: project,
  desc: `Diário de bordo do projeto ${project}.`,
  github: '',
  tags: [],
};

const totalEdicoes = posts.length;

// Projetos disponiveis para inscricao (todos os conhecidos)
const projetosSubscribe = [
  { slug: 'mcp-fiscal-brasil', label: 'MCP Fiscal Brasil' },
];
---

<html lang="pt-BR">
  <head>
    <Head
      title={meta.nome}
      description={meta.desc}
      canonicalURL={new URL(`/${project}/`, Astro.site)}
      project={project}
    />
    <link rel="icon" type="image/png" href="/logo-mcp-fiscal.png" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <Nav />

    <!-- Cabecalho do projeto -->
    <section class="project-hero" aria-labelledby="project-title">
      <div class="project-hero__inner">
        <a href="/" class="back-link">&larr; Projetos</a>

        <h1 class="project-hero__title" id="project-title">{meta.nome}</h1>
        <p class="project-hero__desc">{meta.desc}</p>

        {meta.tags.length > 0 && (
          <div class="project-hero__badges">
            {meta.tags.map((tag) => (
              <span class="badge badge--accent">{tag}</span>
            ))}
          </div>
        )}

        <div class="project-hero__links">
          {meta.github && (
            <a
              href={meta.github}
              target="_blank"
              rel="noopener noreferrer"
              class="link-external"
              aria-label={`Repositorio GitHub de ${meta.nome} (abre em nova aba)`}
            >
              GitHub
            </a>
          )}
          <a
            href={`/${project}/rss.xml`}
            class="link-external"
            aria-label={`Feed RSS do projeto ${meta.nome}`}
          >
            RSS
          </a>
        </div>
      </div>
    </section>

    <main>
      <section class="section" aria-labelledby="edicoes-titulo">
        <div class="container">
          <h2 class="section-label" id="edicoes-titulo">
            {totalEdicoes} {totalEdicoes === 1 ? 'edição publicada' : 'edições publicadas'}
          </h2>
          <div class="editions-list">
            {posts.map((post, idx) => {
              const [, ...restParts] = post.id.split('/');
              const slug = restParts.join('/');
              const numEdition = String(totalEdicoes - idx).padStart(2, '0');
              return (
                <article class="edition-row">
                  <p class="edition-number">EDIÇÃO {numEdition}</p>
                  <h3>
                    <a href={`/${project}/${slug}/`} class="edition-row__title">
                      {post.data.title}
                    </a>
                  </h3>
                  <p class="edition-row__excerpt">{post.data.description}</p>
                  <div class="edition-row__meta">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {post.data.pubDate.toLocaleDateString('pt-BR', {
                        day: '2-digit',
                        month: 'long',
                        year: 'numeric',
                        timeZone: 'America/Sao_Paulo',
                      })}
                    </time>
                    <span aria-hidden="true">&middot;</span>
                    <a href={`/${project}/${slug}/`}>Ler &rarr;</a>
                  </div>
                </article>
              );
            })}
          </div>
        </div>
      </section>
    </main>

    <!-- Inscricao: projeto atual pre-marcado -->
    <SubscribeForm
      projects={projetosSubscribe}
      preChecked={[project]}
      heading={`Acompanhe o ${meta.nome}`}
    />

    <Footer />
  </body>
</html>
