---
import { getCollection } from 'astro:content';
import Head from '../components/Head.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SubscribeForm from '../components/SubscribeForm.astro';
import '../styles/global.css';

const todos = await getCollection('posts', ({ data }) => !data.draft);

// Agrupa por projeto
const porProjeto = todos.reduce((acc: Record<string, typeof todos>, post) => {
  const proj = post.data.project;
  if (!acc[proj]) acc[proj] = [];
  acc[proj].push(post);
  return acc;
}, {});

const projetos = Object.keys(porProjeto).sort();

// Posts recentes (todos, ordenados por data, max 10)
const recentes = [...todos]
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 10);

const siteDescription = 'Novidades e diário de bordo dos projetos open source de Nikolas de Hor - Goiânia, Brasil.';

// Projetos disponíveis para inscricao
const projetosSubscribe = [
  { slug: 'mcp-fiscal-brasil', label: 'MCP Fiscal Brasil' },
];

// Metadados de projetos
const metaProjetos: Record<string, { nome: string; desc: string; github: string }> = {
  'mcp-fiscal-brasil': {
    nome: 'MCP Fiscal Brasil',
    desc: 'Servidor MCP com 44 tools para dados fiscais brasileiros - CNPJ, NF-e, SPED, BCB e Reforma Tributaria. Sem API key obrigatoria.',
    github: 'https://github.com/DeHor-Labs/mcp-fiscal-brasil',
  },
};
---

<html lang="pt-BR">
  <head>
    <Head
      title="news.dehor.com.br"
      description={siteDescription}
      canonicalURL={new URL('/', Astro.site)}
    />
    <link rel="icon" type="image/png" href="/logo-mcp-fiscal.png" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <Nav />

    <!-- Hero -->
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <p class="hero__eyebrow">Open Source &middot; Goiânia, Brasil</p>
        <h1 class="hero__title" id="hero-title">
          Novidades open source<br />de Nikolas de Hor
        </h1>
        <p class="hero__subtitle">
          Projetos e descobertas de um dev de Goiânia - dados fiscais, automação e ferramentas para devs brasileiros.
        </p>
      </div>
    </section>

    <main>
      <!-- Projetos -->
      <section class="section" aria-labelledby="projetos-titulo">
        <div class="container">
          <h2 class="section-label" id="projetos-titulo">Projetos</h2>
          <div>
            {projetos.map((proj) => {
              const meta = metaProjetos[proj];
              const count = porProjeto[proj].length;
              return (
                <a href={`/${proj}/`} class="project-item">
                  <div class="project-item__body">
                    <p class="project-item__name">{meta?.nome ?? proj}</p>
                    {meta?.desc && (
                      <p class="project-item__desc">{meta.desc}</p>
                    )}
                  </div>
                  <span class="project-item__arrow" aria-hidden="true">
                    {count} {count === 1 ? 'edição' : 'edições'} &rarr;
                  </span>
                </a>
              );
            })}
          </div>
        </div>
      </section>

      <!-- Posts recentes -->
      <section class="section" aria-labelledby="recentes-titulo">
        <div class="container">
          <h2 class="section-label" id="recentes-titulo">Publicações recentes</h2>
          <div class="posts-list">
            {recentes.map((post) => {
              const [project, ...restParts] = post.id.split('/');
              const slug = restParts.join('/');
              const metaProj = metaProjetos[project];
              return (
                <article class="post-item">
                  <div class="post-item__meta">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {post.data.pubDate.toLocaleDateString('pt-BR', {
                        day: '2-digit',
                        month: 'short',
                        year: 'numeric',
                        timeZone: 'America/Sao_Paulo',
                      })}
                    </time>
                    <span class="post-item__meta-dot" aria-hidden="true">&middot;</span>
                    <a href={`/${project}/`}>{metaProj?.nome ?? project}</a>
                  </div>
                  <h3>
                    <a href={`/${project}/${slug}/`} class="post-item__title">
                      {post.data.title}
                    </a>
                  </h3>
                  <p class="post-item__excerpt">{post.data.description}</p>
                </article>
              );
            })}
          </div>
        </div>
      </section>
    </main>

    <!-- Inscricao na newsletter -->
    <SubscribeForm
      projects={projetosSubscribe}
      heading="Receba as novidades"
    />

    <Footer />
  </body>
</html>
